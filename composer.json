{
    "name": "crdesign8/laravel-rtc-calculator",
    "description": "Pacote Laravel para integração com a Calculadora da Reforma Tributária do Consumo (RTC) da Receita Federal do Brasil.",
    "keywords": ["laravel", "rtc", "reforma-tributaria", "calculadora", "tributos", "nfe", "ibs", "cbs", "imposto-seletivo"],
    "homepage": "https://github.com/crdesign8/laravel-rtc-calculator",
    "license": "MIT",
    "authors": [
        {
            "name": "crdesign8",
            "homepage": "https://github.com/crdesign8"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/contracts": "^10.0|^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Crdesign8\\LaravelRtcCalculator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Crdesign8\\LaravelRtcCalculator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Crdesign8\\LaravelRtcCalculator\\RtcServiceProvider"
            ],
            "aliases": {
                "Rtc": "Crdesign8\\LaravelRtcCalculator\\Facades\\Rtc"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
